local repo = 'https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/'
local Library = loadstring(game:HttpGet(repo .. 'Library.lua'))()

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local VoidSpamEnabled = false
local DesyncTypes = {CFrame.new(), Vector3.new()}
local isSpoofing = false

loadstring(game:HttpGet('https://raw.githubusercontent.com/Pixeluted/adoniscries/main/Source.lua'))()
    task.wait()

local function RandomNumberRange(a)
    return math.random(-a * 100, a * 100) / 100
end

RunService.Heartbeat:Connect(function()
    if VoidSpamEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        if isSpoofing then return end
        isSpoofing = true

        local hrp = LocalPlayer.Character.HumanoidRootPart
        
        DesyncTypes[1] = hrp.CFrame
        DesyncTypes[2] = hrp.AssemblyLinearVelocity

        local SpoofThis = hrp.CFrame
        
        SpoofThis = SpoofThis + Vector3.new(math.random(-250, 250), math.random(-250, 250), math.random(-250, 250))
        SpoofThis = SpoofThis * CFrame.Angles(math.rad(RandomNumberRange(180)), math.rad(RandomNumberRange(180)), math.rad(RandomNumberRange(180)))

        hrp.CFrame = SpoofThis
        hrp.AssemblyLinearVelocity = Vector3.new(1, 1, 1) * 16384

        task.spawn(function()
            RunService.RenderStepped:Wait()

            if hrp and hrp.Parent then
                hrp.CFrame = DesyncTypes[1]
                hrp.AssemblyLinearVelocity = DesyncTypes[2]
            end
            
            isSpoofing = false
        end)
    end
end)

local XDDDDDD; XDDDDDD = hookmetamethod(game, "__index", newcclosure(function(self, key)
    if VoidSpamEnabled and not checkcaller() then
        if key == "CFrame" and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character:FindFirstChild("Humanoid").Health > 0 then
            if self == LocalPlayer.Character.HumanoidRootPart then
                return DesyncTypes[1] or CFrame.new()
            elseif self == LocalPlayer.Character.Head then
                return DesyncTypes[1] and DesyncTypes[1] + Vector3.new(0, LocalPlayer.Character.HumanoidRootPart.Size.Y / 2 + 0.5, 0) or CFrame.new()
            end
        end
    end
    return XDDDDDD(self, key)
end))

